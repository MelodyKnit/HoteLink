COMPOSE_PROJECT_NAME=hotelink-dev

MYSQL_DATABASE=hotelink_dev
MYSQL_USER=hotelink
MYSQL_PASSWORD=change_me
MYSQL_ROOT_PASSWORD=change_root_me

DB_HOST=mysql
DB_PORT=3306
DB_NAME=hotelink_dev
DB_USER=hotelink
DB_PASSWORD=change_me

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

AI_PROVIDER=deepseek
AI_ENABLED=0
AI_BASE_URL=https://api.deepseek.com
AI_API_KEY=your_deepseek_api_key
AI_MODEL=deepseek-chat
AI_REASONING_MODEL=deepseek-reasoner
AI_TIMEOUT=60

DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=dev_secret_key_change_me_replace_with_a_long_random_value
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8088,http://localhost:5173,http://localhost:5174,http://localhost:8000

BACKEND_PORT=8000
FRONTEND_PORT=8088
USER_WEB_PORT=5173
ADMIN_WEB_PORT=5174
