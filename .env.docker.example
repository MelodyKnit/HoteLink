COMPOSE_PROJECT_NAME=hotelink

MYSQL_DATABASE=hotelink
MYSQL_USER=hotelink
MYSQL_PASSWORD=change_me
MYSQL_ROOT_PASSWORD=change_root_me

DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_WSGI_MODULE=config.wsgi:application
CELERY_APP_MODULE=config
DJANGO_SECRET_KEY=change_this_secret_key_to_a_long_random_value
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=example.com,www.example.com,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com
ENABLE_API_DOCS=0
DJANGO_SECURE_SSL_REDIRECT=1
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=1
DJANGO_SECURE_HSTS_PRELOAD=1
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change_admin_password

DB_HOST=mysql
DB_PORT=3306
DB_NAME=hotelink
DB_USER=hotelink
DB_PASSWORD=change_me

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

AI_PROVIDER=deepseek
AI_ENABLED=0
AI_BASE_URL=https://api.deepseek.com
AI_API_KEY=your_deepseek_api_key
AI_MODEL=deepseek-chat
AI_REASONING_MODEL=deepseek-reasoner
AI_TIMEOUT=60

JWT_ROTATE_REFRESH_TOKENS=1
JWT_BLACKLIST_AFTER_ROTATION=1
API_THROTTLE_AUTH_LOGIN=5/minute
API_THROTTLE_AUTH_REFRESH=20/minute
API_THROTTLE_AUTH_LOGOUT=30/minute
API_THROTTLE_UPLOAD=20/hour
API_THROTTLE_AI_USER=30/hour
API_THROTTLE_AI_ADMIN=60/hour

GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=120
RUN_MIGRATIONS=1
RUN_COLLECTSTATIC=1
