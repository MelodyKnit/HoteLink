{
  "name": "hotelink-frontend",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:user\" \"npm run dev:admin\"",
    "dev:user": "npm --workspace @hotelink/user-web run dev -- --host 0.0.0.0 --port 5173",
    "dev:admin": "npm --workspace @hotelink/admin-web run dev -- --host 0.0.0.0 --port 5174",
    "build": "npm run build:user && npm run build:admin",
    "build:user": "npm run build --workspace @hotelink/user-web",
    "build:admin": "npm run build --workspace @hotelink/admin-web",
    "test:unit": "vitest",
    "test:unit:ci": "vitest run",
    "type-check": "npm run type-check:user && npm run type-check:admin",
    "type-check:user": "npm run type-check --workspace @hotelink/user-web",
    "type-check:admin": "npm run type-check --workspace @hotelink/admin-web"
  },
  "dependencies": {
    "@vueuse/core": "^13.1.0",
    "axios": "^1.8.4",
    "echarts": "^5.6.0",
    "marked": "^15.0.12",
    "pinia": "^3.0.2",
    "vue": "^3.5.13",
    "vue-echarts": "^7.0.3",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@vitejs/plugin-vue": "^5.2.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "less": "^4.2.2",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vite": "^6.2.2",
    "vitest": "^3.0.9",
    "vue-tsc": "^2.2.8"
  }
}
